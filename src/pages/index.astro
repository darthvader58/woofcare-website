---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="container hero-container">
      <div class="hero-content">
        <h1>WoofCare</h1>
        <p class="hero-tagline">Where Every Bark Finds a Helping Hand</p>
        <p class="hero-description">
          Connect with dog-help resources in your vicinity to find home and care for abandoned stray dogs.
        </p>
        <div class="hero-buttons">
          <a href="/join" class="btn btn-primary">Join the Movement</a>
        </div>
        <div class="coming-soon">
          <a href="/WoofCare.apk" class="apk-download" download>
            <span class="download-icon" aria-hidden="true">
              <svg viewBox="0 0 24 24" focusable="false">
                <path d="M12 3a1 1 0 0 1 1 1v8.59l2.3-2.3a1 1 0 1 1 1.4 1.42l-4 4a1 1 0 0 1-1.4 0l-4-4a1 1 0 1 1 1.4-1.42l2.3 2.3V4a1 1 0 0 1 1-1Z"/>
                <path d="M5 18a1 1 0 0 1 1-1h12a1 1 0 1 1 0 2H6a1 1 0 0 1-1-1Z"/>
              </svg>
            </span>
            <span>
              <strong>Download APK</strong>
              <small>Android only</small>
            </span>
          </a>
          <div class="store-badge-container">
            <div class="store-badges">
              <span class="store-badge disabled">
                <span class="store-icon play-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M4.7 3.2c-.28.2-.45.55-.45 1v15.6c0 .45.17.8.45 1l8.33-8.8L4.7 3.2Z"/>
                    <path d="M14.2 10.76 16.68 8.14 6.62 2.56l7.58 8.2Z"/>
                    <path d="M14.2 13.24 6.62 21.44l10.06-5.58-2.48-2.62Z"/>
                    <path d="m17.82 8.78-2.9 3.22 2.9 3.22 1.9-1.05c1.38-.77 1.38-3.57 0-4.34l-1.9-1.05Z"/>
                  </svg>
                </span>
                <span>Play Store</span>
              </span>
              <span class="store-badge disabled">
                <span class="store-icon app-store-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M15.85 3.18c.06 1.18-.4 2.29-1.16 3.13-.8.88-2.06 1.56-3.1 1.47-.1-1.13.42-2.27 1.16-3.08.82-.9 2.2-1.58 3.1-1.52Z"/>
                    <path d="M19.18 16.56c-.43.98-.64 1.42-1.2 2.3-.78 1.22-1.88 2.74-3.24 2.75-1.2.02-1.52-.8-3.16-.8-1.64 0-2 .78-3.2.82-1.36.04-2.4-1.32-3.18-2.54-2.18-3.4-2.42-7.38-1.07-9.5.96-1.5 2.47-2.38 3.9-2.38 1.45 0 2.37.8 3.56.8 1.16 0 1.86-.8 3.54-.8 1.26 0 2.6.68 3.55 1.86-3.12 1.72-2.62 6.18.5 7.49Z"/>
                  </svg>
                </span>
                <span>App Store</span>
              </span>
            </div>
            <p class="store-note">App launching soon</p>
          </div>
        </div>
      </div>
      <div class="hero-image">
        <div class="product-visual" aria-hidden="true">
          <div class="phone-shell">
            <div class="phone-screen">
              <div class="screen-status"></div>
              <div class="screen-logo"><img src="logo.svg" alt=""/></div>
              <div class="screen-line wide"></div>
              <div class="screen-line"></div>
              <div class="screen-card large"></div>
              <div class="screen-grid">
                <span></span>
                <span></span>
                <span></span>
              </div>
            </div>
          </div>
          <div class="floating-panel panel-one"></div>
          <div class="floating-panel panel-two"></div>
          <div class="floating-panel panel-three"></div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Section -->
  <section class="section problem-section">
    <div class="container">
      <h2 class="section-title">The Challenge We're Solving</h2>
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/>
            </svg>
          </div>
          <h3>Dog Lovers' Dilemma</h3>
          <p>Many compassionate people want to help stray dogs but face challenges with household situations, financial constraints, and limited access to veterinary care.</p>
        </div>
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="currentColor"/>
            </svg>
          </div>
          <h3>Overwhelmed NGOs</h3>
          <p>Animal welfare organizations struggle with limited space, resources, financial assistance, and network reach to help all dogs in need.</p>
        </div>
        <div class="problem-card">
          <div class="problem-icon">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" fill="currentColor"/>
            </svg>
          </div>
          <h3>Finding Help is Hard</h3>
          <p>Locating dog shelters, adoption centers, and veterinary services in your area is often difficult and time-consuming.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Solution Section -->
  <section class="section solution-section">
    <div class="container">
      <h2 class="section-title">Our Solution</h2>
      <p class="section-subtitle">A social-media networking app that connects all dog lovers with dog resources in the vicinity.</p>
      
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-number">01</div>
          <h3>Report Need for Care</h3>
          <p>Easily report stray dogs that need help directly through the app with location and details.</p>
        </div>
        <div class="feature-card">
          <div class="feature-number">02</div>
          <h3>Help or Find Help</h3>
          <p>Connect with nearby resources including vet clinics, rescue shelters, NGOs, and potential adopters.</p>
        </div>
        <div class="feature-card">
          <div class="feature-number">03</div>
          <h3>Inspire Others</h3>
          <p>Share success stories and build a community of dog lovers making a real difference.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Resources Section -->
  <section class="section resources-section">
    <div class="container">
      <h2 class="section-title">Dog Help Resources</h2>
      <div class="resources-grid">
        <div class="resource-item">
          <span class="resource-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z" fill="currentColor"/>
            </svg>
          </span>
          <span>Vet Clinics</span>
        </div>
        <div class="resource-item">
          <span class="resource-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z" fill="currentColor"/>
            </svg>
          </span>
          <span>Dog Lovers</span>
        </div>
        <div class="resource-item">
          <span class="resource-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M8.1 13.34l2.83-2.83L3.91 3.5c-1.56 1.56-1.56 4.09 0 5.66l4.19 4.18zm6.78-1.81c1.53.71 3.68.21 5.27-1.38 1.91-1.91 2.28-4.65.81-6.12-1.46-1.46-4.20-1.10-6.12.81-1.59 1.59-2.09 3.74-1.38 5.27L3.7 19.87l1.41 1.41L12 14.41l6.88 6.88 1.41-1.41L14.88 11.53z" fill="currentColor"/>
            </svg>
          </span>
          <span>Dog Feeders</span>
        </div>
        <div class="resource-item">
          <span class="resource-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M10 20v-6h4v6h5v-8h3L12 3 2 12h3v8z" fill="currentColor"/>
            </svg>
          </span>
          <span>Rescue Shelters</span>
        </div>
        <div class="resource-item">
          <span class="resource-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M16 4c0-1.11.89-2 2-2s2 .89 2 2-.89 2-2 2-2-.89-2-2zm4 18v-6h2.5l-2.54-7.63A1.5 1.5 0 0 0 18.54 8H16c-.8 0-1.54.37-2.01 1l-2.41 3.19c-.32.42-.26 1.02.14 1.37l2.41 2.13L12.92 18H11v2h1.5c.28 0 .5-.22.5-.5 0-.1-.04-.19-.1-.26L11.18 18H9.97L8 16.5l1.18-1.18L11.5 17H13l2.5-3.22L12.4 11.2C12.18 11.07 12 10.84 12 10.5c0-.83.67-1.5 1.5-1.5H16l2.54 7.63L20 22z" fill="currentColor"/>
            </svg>
          </span>
          <span>NGOs</span>
        </div>
        <div class="resource-item">
          <span class="resource-icon">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M12 3L2 12h3v8h6v-6h2v6h6v-8h3L12 3zm5 15h-2v-6H9v6H7v-6.81l5-4.5 5 4.5V18z" fill="currentColor"/>
            </svg>
          </span>
          <span>Adoption Centers</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="section cta-section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Make a Difference?</h2>
        <p>Join WoofCare and help create a world where every bark finds a helping hand.</p>
        <a href="/contact" class="btn btn-primary">Contact Us</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section - Fully Responsive */
  .hero {
    background: var(--cream);
    padding: 2rem 0;
    position: relative;
    overflow: hidden;
  }

  .hero-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    align-items: center;
    min-height: 50vh;
  }

  .hero-content {
    padding: 1rem 0;
  }

  .hero-content h1 {
    font-size: clamp(2.5rem, 8vw, 4rem);
    color: var(--primary-brown);
    margin-bottom: 0.75rem;
    line-height: 1.1;
  }

  .hero-tagline {
    font-size: clamp(1.1rem, 3vw, 1.5rem);
    color: var(--dark-brown);
    font-weight: 600;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .hero-description {
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    margin-bottom: 1.5rem;
    max-width: 500px;
    line-height: 1.6;
  }

  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .hero-buttons .btn {
    flex: 1 1 auto;
    min-width: 140px;
    max-width: 220px;
    padding: 0.875rem 1.5rem;
    font-size: clamp(0.9rem, 2vw, 1rem);
    white-space: nowrap;
  }

  .coming-soon {
    margin-top: 1.5rem;
  }

  .hero-image {
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 200px;
  }

  .dog-illustration {
    font-size: clamp(8rem, 25vw, 15rem);
    animation: float 3s ease-in-out infinite;
    max-width: 100%;
  }

  .dog-illustration img {
    max-width: 100%;
    height: auto;
    display: block;
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* Problem Section */
  .problem-section {
    background-color: var(--white);
  }

  .section-title {
    text-align: center;
    color: var(--primary-brown);
    margin-bottom: 3rem;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .problem-card {
    background-color: var(--light-cream);
    padding: 2rem;
    border-radius: 12px;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .problem-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 20px rgba(184, 121, 43, 0.2);
  }

  .problem-icon {
    color: var(--primary-brown);
    margin-bottom: 1rem;
    display: flex;
    justify-content: center;
  }

  .problem-icon svg {
    width: 48px;
    height: 48px;
  }

  .problem-card h3 {
    color: var(--dark-brown);
    margin-bottom: 1rem;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
  }

  .problem-card p {
    font-size: clamp(0.95rem, 2vw, 1rem);
  }

  /* Solution Section */
  .solution-section {
    background: var(--cream);
  }

  .section-subtitle {
    text-align: center;
    font-size: clamp(1.05rem, 2.2vw, 1.2rem);
    max-width: 700px;
    margin: 0 auto 3rem;
    line-height: 1.6;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .feature-card {
    background-color: var(--white);
    padding: 2rem;
    border-radius: 12px;
    border-left: 5px solid var(--primary-brown);
    transition: all 0.3s ease;
  }

  .feature-card:hover {
    transform: translateX(10px);
    box-shadow: 0 8px 20px rgba(184, 121, 43, 0.2);
  }

  .feature-number {
    font-size: 2rem;
    font-weight: 700;
    color: var(--primary-brown);
    margin-bottom: 1rem;
  }

  .feature-card h3 {
    color: var(--dark-brown);
    margin-bottom: 1rem;
    font-size: clamp(1.2rem, 2.5vw, 1.5rem);
  }

  .feature-card p {
    font-size: clamp(0.95rem, 2vw, 1rem);
  }

  /* Resources Section */
  .resources-section {
    background-color: var(--white);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }

  .resource-item {
    background-color: var(--cream);
    padding: 1.5rem;
    border-radius: 12px;
    text-align: center;
    font-weight: 600;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    font-size: clamp(0.9rem, 2vw, 1rem);
  }

  .resource-item:hover {
    transform: scale(1.05);
  }

  .resource-icon {
    color: var(--primary-brown);
    display: flex;
    justify-content: center;
  }

  .resource-icon svg {
    width: 32px;
    height: 32px;
  }

  /* CTA Section */
  .cta-section {
    background: var(--primary-brown);
    color: var(--white);
  }

  .cta-content {
    text-align: center;
    padding: 2rem;
  }

  .cta-content h2 {
    color: var(--white);
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    margin-bottom: 1rem;
  }

  .cta-content p {
    color: var(--light-cream);
    font-size: clamp(1rem, 2.2vw, 1.2rem);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .cta-content .btn-primary {
    background: var(--white);
    color: var(--deep-brown);
    border: 2px solid var(--light-brown);
    box-shadow: 0 16px 34px rgba(0, 0, 0, 0.22);
  }

  .cta-content .btn-primary:hover {
    background: var(--cream);
    color: var(--deep-brown);
    border-color: var(--white);
  }

  .hero {
    isolation: isolate;
    background: var(--cream);
    padding: clamp(4rem, 8vw, 7rem) 0 clamp(3rem, 6vw, 5rem);
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: auto 0 0;
    height: 44%;
    background: rgba(255, 255, 255, 0.38);
    pointer-events: none;
    z-index: -1;
  }

  .hero-container {
    min-height: clamp(560px, 72vh, 760px);
    gap: clamp(2rem, 6vw, 5rem);
  }

  .hero-content {
    position: relative;
    z-index: 2;
  }

  .hero-content h1 {
    color: var(--deep-brown);
    font-size: clamp(3.25rem, 9vw, 6.8rem);
    letter-spacing: 0;
    margin-bottom: 1rem;
  }

  .hero-tagline {
    color: var(--primary-brown);
    font-size: clamp(1.2rem, 2.4vw, 1.75rem);
    font-weight: 850;
  }

  .hero-description {
    color: var(--text-medium);
    font-size: clamp(1.05rem, 1.7vw, 1.25rem);
    max-width: 34rem;
  }

  .coming-soon {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem;
    border: 1px solid rgba(111, 67, 31, 0.18);
    border-radius: 24px;
    background: var(--white);
    box-shadow: var(--shadow-sm);
  }

  .coming-soon p {
    margin: 0;
  }

  .apk-download {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    min-height: 4.4rem;
    padding: 0.85rem 1.1rem;
    border-radius: 18px;
    background: var(--primary-brown);
    border: 2px solid var(--dark-brown);
    color: var(--white);
    box-shadow: 0 12px 26px rgba(61, 40, 23, 0.14);
  }

  .apk-download:hover {
    background: var(--dark-brown);
    color: var(--white);
    transform: translateY(-2px);
  }

  .apk-download strong,
  .apk-download small {
    display: block;
    color: inherit;
    line-height: 1.1;
  }

  .apk-download strong {
    font-size: 1.02rem;
    margin-bottom: 0.18rem;
  }

  .apk-download small {
    font-size: 0.78rem;
    font-weight: 700;
    opacity: 0.86;
  }

  .download-icon,
  .store-icon {
    display: inline-grid;
    place-items: center;
    flex: 0 0 auto;
  }

  .download-icon {
    width: 2rem;
    height: 2rem;
    border-radius: 11px;
    background: var(--white);
    color: var(--primary-brown);
  }

  .download-icon svg,
  .store-icon svg {
    width: 1.25rem;
    height: 1.25rem;
    fill: currentColor;
  }

  .store-badge-container {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    align-items: center;
  }

  .store-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
  }

  .store-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    min-height: 3.2rem;
    padding: 0.7rem 0.95rem;
    border-radius: 16px;
    font-size: 0.95rem;
    font-weight: 800;
    white-space: nowrap;
  }

  .store-badge.disabled {
    background: var(--light-cream);
    color: var(--dark-brown);
    border: 1px solid rgba(111, 67, 31, 0.16);
    opacity: 1;
    cursor: not-allowed;
  }

  .store-icon {
    width: 1.8rem;
    height: 1.8rem;
    border-radius: 10px;
    background: var(--white);
    color: var(--primary-brown);
    border: 1px solid rgba(111, 67, 31, 0.12);
  }

  .store-note {
    color: var(--text-muted);
    font-size: 0.92rem;
    font-style: italic;
    font-weight: 800;
    letter-spacing: 0.06em;
  }

  .hero-image {
    min-height: 520px;
    position: relative;
  }

  .product-visual {
    position: relative;
    width: min(100%, 480px);
    aspect-ratio: 0.88;
    display: grid;
    place-items: center;
  }

  .product-visual::before {
    content: '';
    position: absolute;
    width: 92%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: var(--light-cream);
    border: 1px solid rgba(111, 67, 31, 0.08);
    box-shadow: var(--shadow-lg);
  }

  .phone-shell {
    position: relative;
    width: min(74%, 315px);
    aspect-ratio: 0.54;
    padding: 0.78rem;
    border-radius: 38px;
    background: var(--deep-brown);
    box-shadow: 0 34px 90px rgba(61, 40, 23, 0.26);
    transform: rotate(5deg);
    z-index: 2;
  }

  .phone-screen {
    height: 100%;
    overflow: hidden;
    border-radius: 29px;
    background: var(--white);
    border: 1px solid rgba(255, 255, 255, 0.22);
    padding: 1.1rem;
  }

  .screen-status {
    width: 34%;
    height: 0.38rem;
    border-radius: 999px;
    background: rgba(61, 40, 23, 0.16);
