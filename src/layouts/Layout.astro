---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "WoofCare - Where Every Bark Finds a Helping Hand. Connect with dog-help resources to find home and care for abandoned stray dogs." } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="keywords" content="stray dogs, dog rescue, dog adoption, animal welfare, NGO, dog care">
  <title>{title} | WoofCare</title>
  
  <!-- Favicons -->
  <link rel="icon" type="image/svg+xml" href="/favicon.ico">
  <meta name="theme-color" content="#B8792B">
</head>
<body>
  <header class="header">
    <nav class="nav">
      <div class="container nav-container">
        <a href="/" class="logo">WoofCare</a>
        
        <!-- Hamburger Menu Button -->
        <button class="hamburger" id="hamburger" aria-label="Toggle menu">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </button>

        <!-- Navigation Menu -->
        <ul class="nav-menu" id="navMenu">
          <li><a href="/about" class="nav-link">About</a></li>
          <li><a href="/join" class="nav-link">Help Us</a></li>
          <li><a href="/contact" class="nav-link">Contact</a></li>
        </ul>
      </div>
    </nav>
  </header>

  <main>
    <slot />
  </main>

  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <div class="footer-section">
          <h3>WoofCare</h3>
          <p>Where Every Bark Finds a Helping Hand</p>
          <p class="tagline">"Animals have no voice. Humanity must be their voice." - A.D Williams</p>
        </div>
        <div class="footer-section">
          <h4>Quick Links</h4>
          <ul>
            <li><a href="/">Home</a></li>
            <li><a href="/about">About</a></li>
            <li><a href="/join">Join Us</a></li>
            <li><a href="/contact">Contact</a></li>
          </ul>
        </div>
        <div class="footer-section">
          <h4>Contact</h4>
          <p>Email: woofcareepics@gmail.com</p>
          <p>Coming Soon on Google Play</p>
        </div>
      </div>
      <div class="footer-bottom">
        <p>&copy; 2025 WoofCare. All rights reserved.</p>
      </div>
    </div>
  </footer>
</body>
</html>

<style>
  .header {
    background: rgba(255, 253, 248, 0.84);
    border-bottom: 1px solid rgba(111, 67, 31, 0.1);
    box-shadow: 0 12px 34px rgba(61, 40, 23, 0.06);
    backdrop-filter: blur(18px);
    position: sticky;
    top: 0;
    z-index: 1000;
  }

  .nav {
    padding: 0.85rem 0;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
  }

  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    font-size: 1.55rem;
    font-weight: 900;
    text-decoration: none;
    z-index: 1001;
    letter-spacing: 0;
  }

  .logo::before {
    content: '';
    width: 2.45rem;
    height: 2.45rem;
    border-radius: 14px;
    background: var(--white) url('/logo.svg') center / 78% no-repeat;
    border: 1px solid rgba(111, 67, 31, 0.2);
    box-shadow: 0 10px 24px rgba(184, 121, 43, 0.22);
  }

  .logo-woof {
    color: var(--dark-brown);
  }

  .logo-care {
    color: var(--dark-brown);
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: space-between;
    width: 30px;
    height: 24px;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0;
    z-index: 1001;
  }

  .hamburger-line {
    width: 100%;
    height: 3px;
    background-color: var(--dark-brown);
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: translateY(10.5px) rotate(45deg);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: translateY(-10.5px) rotate(-45deg);
  }

  /* Navigation Menu */
  .nav-menu {
    display: flex;
    list-style: none;
    gap: 0.35rem;
    margin: 0;
    padding: 0;
    align-items: center;
    background: rgba(255, 255, 255, 0.64);
    border: 1px solid rgba(111, 67, 31, 0.12);
    border-radius: 999px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.75);
  }

  .nav-menu li {
    margin: 0;
  }

  .nav-link {
    color: var(--text-dark);
    font-weight: 750;
    padding: 0.7rem 1rem;
    border-radius: 999px;
    transition: all 0.2s ease;
    display: block;
  }

  .nav-link:hover {
    background-color: rgba(250, 243, 232, 0.9);
    color: var(--primary-brown);
  }

  @media (max-width: 820px) {
    .hamburger {
      display: flex;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: min(82vw, 320px);
      height: 100vh;
      background: rgba(255, 253, 248, 0.98);
      flex-direction: column;
      gap: 0;
      padding: 5rem 2rem 2rem;
      border-radius: 0;
      border: 0;
      box-shadow: -18px 0 45px rgba(61, 40, 23, 0.16);
      transition: right 0.3s ease;
      align-items: stretch;
    }

    .nav-menu.active {
      right: 0;
    }

    .nav-menu li {
      width: 100%;
    }

    .nav-link {
      width: 100%;
      padding: 1rem;
      font-size: 1.1rem;
      border-bottom: 1px solid rgba(111, 67, 31, 0.12);
    }

    .nav-link:hover {
      background-color: var(--cream);
      border-radius: 8px;
    }
  }

  .nav-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5);
    z-index: 999;
  }

  .nav-overlay.active {
    display: block;
  }

  .footer {
    background: var(--primary-brown);
    color: var(--white);
    border-top: 1px solid rgba(255, 255, 255, 0.34);
    padding: 4rem 0 1.25rem;
    margin-top: 0;
    position: relative;
    overflow: hidden;
  }

  .footer::before {
    content: '';
    position: absolute;
    inset: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.22);
    border-radius: 28px;
    pointer-events: none;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.4fr 0.8fr 1fr;
    gap: 2.5rem;
    margin-bottom: 2.5rem;
    position: relative;
    z-index: 1;
  }

  .footer-section h3,
  .footer-section h4 {
    color: var(--white);
    margin-bottom: 1rem;
    letter-spacing: 0;
  }

  .footer-section p,
  .footer-section li {
    color: var(--white);
    opacity: 0.92;
  }

  .footer-section ul {
    list-style: none;
  }

  .footer-section a {
    color: var(--white);
  }

  .footer-section a:hover {
    color: var(--white);
  }

  .tagline {
    font-style: italic;
    font-size: 0.9rem;
    margin-top: 1rem;
    max-width: 32rem;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.26);
    padding-top: 1rem;
    text-align: center;
    position: relative;
    z-index: 1;
  }

  .footer-bottom p {
    color: var(--white);
    font-size: 0.9rem;
  }

  @media (max-width: 820px) {
    .footer {
      padding-top: 3rem;
    }

    .footer::before {
      inset: 0.75rem;
      border-radius: 20px;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('hamburger');
  const navMenu = document.getElementById('navMenu');

  const overlay = document.createElement('div');
  overlay.className = 'nav-overlay';
  document.body.appendChild(overlay);

  function toggleMenu() {
    hamburger?.classList.toggle('active');
    navMenu?.classList.toggle('active');
    overlay.classList.toggle('active');
    
    if (navMenu?.classList.contains('active')) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = '';
    }
  }

  hamburger?.addEventListener('click', toggleMenu);

  overlay.addEventListener('click', toggleMenu);

  const navLinks = navMenu?.querySelectorAll('.nav-link');
  navLinks?.forEach(link => {
    link.addEventListener('click', () => {
      if (navMenu?.classList.contains('active')) {
        toggleMenu();
      }
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth > 820 && navMenu?.classList.contains('active')) {
      toggleMenu();
    }
  });
</script>
