---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Bug Report" description="Report an in-app or website issue to the WoofCare team with a screenshot or screen recording.">
  <section class="bug-hero">
    <div class="container">
      <p class="eyebrow">Product Support</p>
      <h1>Report a Bug</h1>
      <p class="hero-subtitle">Found something broken in the WoofCare app or website? Send the details and a screenshot or screen recording so we can investigate quickly.</p>
    </div>
  </section>

  <section class="section bug-section">
    <div class="container bug-layout">
      <div class="bug-form-container">
        <div class="form-header">
          <h2>Bug Details</h2>
          <p>Share what happened and attach the visual evidence of the issue. Screen recordings are accepted when a bug is easier to show in motion.</p>
        </div>

        <form class="bug-form" id="bugForm" novalidate>
          <div class="form-group">
            <label for="issueArea">Where did you find the issue?</label>
            <select id="issueArea" name="issueArea">
              <option value="App">WoofCare app</option>
              <option value="Website">WoofCare website</option>
              <option value="Both">Both app and website</option>
              <option value="Not sure">Not sure</option>
            </select>
          </div>

          <div class="form-group">
            <label for="issueDescription">Issue description *</label>
            <textarea
              id="issueDescription"
              name="issueDescription"
              rows="7"
              required
              placeholder="Describe what happened, what you expected instead, and any steps that help reproduce the issue."
            ></textarea>
            <span class="error-message" id="issueDescription-error"></span>
          </div>

          <div class="form-group">
            <label for="issueMedia">Screenshot or screen recording *</label>
            <label class="file-dropzone" for="issueMedia">
              <span class="file-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2Zm0 12.8-3.5-3.51a1 1 0 0 0-1.42 0L12 14.38l-1.58-1.59a1 1 0 0 0-1.42 0L5 16.79V5h14v10.8ZM8.5 9.5A1.5 1.5 0 1 1 10 8a1.5 1.5 0 0 1-1.5 1.5Z"/>
                </svg>
              </span>
              <span class="file-dropzone-text">
                <strong>Upload a screenshot or screen recording</strong>
                <small>Accepted files: images and videos</small>
              </span>
            </label>
            <input
              type="file"
              id="issueMedia"
              name="issueMedia"
              accept="image/*,video/*"
              required
            />
            <span class="selected-file" id="selectedFile">No file selected</span>
            <span class="error-message" id="issueMedia-error"></span>
          </div>

          <div class="form-grid">
            <div class="form-group">
              <label for="deviceInfo">Device or browser</label>
              <input
                type="text"
                id="deviceInfo"
                name="deviceInfo"
                placeholder="iPhone 15, Chrome on Windows, Android phone..."
              />
            </div>

            <div class="form-group">
              <label for="contactEmail">Email for follow-up</label>
              <input
                type="email"
                id="contactEmail"
                name="contactEmail"
                placeholder="you@example.com"
              />
              <span class="error-message" id="contactEmail-error"></span>
            </div>
          </div>

          <button type="submit" class="btn btn-primary submit-btn">
            <span class="btn-text">Submit Bug Report</span>
            <span class="btn-loader" style="display: none;">Uploading...</span>
          </button>
        </form>

        <div id="formMessage" class="form-message"></div>
      </div>

      <aside class="bug-info">
        <div class="info-card">
          <h3>What helps us fix it faster?</h3>
          <p>A clear description, the screen where it happened, and a screenshot or short recording of the issue.</p>
        </div>

        <div class="info-card">
          <h3>App or website issues</h3>
          <p>Use this form for broken buttons, display issues, crashes, upload failures, login problems, or confusing behavior.</p>
        </div>

        <div class="info-card">
          <h3>Private details</h3>
          <p>Please avoid uploading passwords, payment information, or personal documents in screenshots or recordings.</p>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<style>
  .bug-hero {
    background: var(--primary-brown);
    color: var(--white);
    padding: clamp(5rem, 10vw, 8rem) 0;
    text-align: center;
  }

  .bug-hero h1 {
    color: var(--white);
    font-size: clamp(3rem, 8vw, 5.6rem);
    margin-bottom: 1rem;
  }

  .eyebrow {
    color: var(--light-cream);
    font-size: 0.9rem;
    font-weight: 800;
    letter-spacing: 0;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .hero-subtitle {
    color: var(--light-cream);
    font-size: 1.25rem;
    line-height: 1.55;
    max-width: 820px;
    margin: 1.5rem auto 0;
  }

  .bug-section {
    background: var(--light-cream);
  }

  .bug-layout {
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(280px, 0.75fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .bug-form-container {
    background: rgba(255, 255, 255, 0.9);
    border: 1px solid var(--border-soft);
    border-radius: 28px;
    box-shadow: var(--shadow-md);
    padding: clamp(1.5rem, 4vw, 3rem);
  }

  .form-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .form-header h2 {
    color: var(--deep-brown);
    font-size: 2rem;
  }

  .form-header p {
    color: var(--text-medium);
    font-size: 1.05rem;
    margin: 0 auto;
    max-width: 680px;
  }

  .bug-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
  }

  .form-group label {
    color: var(--text-dark);
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.875rem;
    border: 1px solid rgba(111, 67, 31, 0.16);
    border-radius: 16px;
    background: var(--light-cream);
    color: var(--text-dark);
    font-family: inherit;
    font-size: 1rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease, background-color 0.3s ease;
  }

  .form-group textarea {
    min-height: 160px;
    resize: vertical;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--primary-brown);
    background: var(--white);
    box-shadow: 0 0 0 4px rgba(184, 121, 43, 0.1);
  }

  .form-group input.error,
  .form-group textarea.error {
    border-color: #b3261e;
    box-shadow: 0 0 0 4px rgba(179, 38, 30, 0.1);
  }

  .form-group input[type="file"] {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
  }

  .file-dropzone {
    align-items: center;
    border: 1.5px dashed rgba(111, 67, 31, 0.28);
    border-radius: 20px;
    background: var(--light-cream);
    color: var(--text-dark);
    cursor: pointer;
    display: flex;
    gap: 1rem;
    margin-bottom: 0.6rem;
    min-height: 8rem;
    padding: 1.5rem;
    transition: border-color 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
  }

  .file-dropzone:hover,
  .file-dropzone:focus-within {
    background: var(--white);
    border-color: var(--primary-brown);
    box-shadow: 0 0 0 4px rgba(184, 121, 43, 0.1);
  }

  .file-icon {
    align-items: center;
    background: rgba(184, 121, 43, 0.1);
    border-radius: 18px;
    color: var(--primary-brown);
    display: inline-flex;
    flex: 0 0 auto;
    height: 3.5rem;
    justify-content: center;
    width: 3.5rem;
  }

  .file-icon svg {
    fill: currentColor;
    height: 1.8rem;
    width: 1.8rem;
  }

  .file-dropzone-text {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .file-dropzone-text strong {
    color: var(--deep-brown);
    font-size: 1.05rem;
  }

  .file-dropzone-text small,
  .selected-file {
    color: var(--text-medium);
    font-size: 0.9rem;
  }

  .selected-file {
    display: block;
  }

  .error-message {
    color: #b3261e;
    display: block;
    font-size: 0.875rem;
    font-style: italic;
    margin-top: 0.25rem;
    min-height: 1.2rem;
  }

  .submit-btn {
    font-size: 1.1rem;
    margin-top: 0.5rem;
    padding: 1rem 2rem;
    width: 100%;
  }

  .submit-btn:disabled {
    cursor: not-allowed;
    opacity: 0.65;
  }

  .form-message {
    border-radius: 12px;
    display: none;
    font-size: 1.05rem;
    font-weight: 700;
    margin-top: 1.5rem;
    padding: 1.25rem;
    text-align: center;
  }

  .form-message.success {
    background-color: #d4edda;
    border: 2px solid #28a745;
    color: #155724;
    display: block;
  }

  .form-message.error {
    background-color: #f8d7da;
    border: 2px solid #dc3545;
    color: #721c24;
    display: block;
  }

  .bug-info {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .info-card {
    background: rgba(255, 255, 255, 0.88);
    border: 1px solid var(--border-soft);
    border-radius: 22px;
    box-shadow: var(--shadow-sm);
    padding: 1.5rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .info-card:hover {
    box-shadow: var(--shadow-md);
    transform: translateY(-5px);
  }

  .info-card h3 {
    color: var(--dark-brown);
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .info-card p {
    margin-bottom: 0;
  }

  @media (max-width: 968px) {
    .bug-layout {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .bug-hero h1 {
      font-size: 2.5rem;
    }

    .hero-subtitle {
      font-size: 1.1rem;
    }

    .bug-form-container {
      border-radius: 24px;
    }

    .form-grid {
      grid-template-columns: 1fr;
    }

    .file-dropzone {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

<script type="module">
  import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-app.js';
  import { getFirestore, collection, addDoc, serverTimestamp } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-firestore.js';
  import { getStorage, ref, uploadBytes, getDownloadURL } from 'https://www.gstatic.com/firebasejs/10.7.1/firebase-storage.js';

  const firebaseConfig = {
    apiKey: "AIzaSyCvzQDGbU8ndDGJ3mGCeWA0mSsCNRhsbt0",
    authDomain: "woofcare-a9fac.firebaseapp.com",
    projectId: "woofcare-a9fac",
    storageBucket: "woofcare-a9fac.firebasestorage.app",
    messagingSenderId: "506976961145",
    appId: "1:506976961145:web:551d2afd7dc9f0e8240aa8",
    measurementId: "G-FJDV4K81CK"
  };

  const app = initializeApp(firebaseConfig);
  const db = getFirestore(app);
  const storage = getStorage(app);

  const form = document.getElementById('bugForm');
  const formMessage = document.getElementById('formMessage');
  const submitBtn = form?.querySelector('.submit-btn');
  const btnText = submitBtn?.querySelector('.btn-text');
  const btnLoader = submitBtn?.querySelector('.btn-loader');
  const mediaInput = document.getElementById('issueMedia');
  const selectedFile = document.getElementById('selectedFile');

  function setFieldError(id, message) {
    const field = document.getElementById(id);
    const errorElement = document.getElementById(`${id}-error`);

    if (errorElement) {
      errorElement.textContent = message;
    }

    if (field) {
      field.classList.toggle('error', Boolean(message));
    }
  }

  function clearErrors() {
    document.querySelectorAll('.error-message').forEach((element) => {
      element.textContent = '';
    });

    document.querySelectorAll('.error').forEach((element) => {
      element.classList.remove('error');
    });
  }

  function validateForm() {
    clearErrors();

    let isValid = true;
    let firstErrorField = null;
    const description = document.getElementById('issueDescription');
    const email = document.getElementById('contactEmail');
    const file = mediaInput?.files?.[0];

    if (!description?.value.trim()) {
      setFieldError('issueDescription', 'Please describe the issue.');
      firstErrorField = description;
      isValid = false;
    }

    if (!file) {
      setFieldError('issueMedia', 'Please upload a screenshot or screen recording.');
      firstErrorField = firstErrorField || mediaInput;
      isValid = false;
    } else if (!file.type.startsWith('image/') && !file.type.startsWith('video/')) {
      setFieldError('issueMedia', 'Please upload an image or video file.');
      firstErrorField = firstErrorField || mediaInput;
      isValid = false;
    }

    if (email?.value.trim() && !email.checkValidity()) {
      setFieldError('contactEmail', 'Please enter a valid email address.');
      firstErrorField = firstErrorField || email;
      isValid = false;
    }

    if (!isValid && firstErrorField) {
      firstErrorField.scrollIntoView({
        behavior: 'smooth',
        block: 'center'
      });
      firstErrorField.focus();
    }

    return isValid;
  }

  function sanitizeFileName(fileName) {
    return fileName.replace(/[^a-z0-9._-]/gi, '-').replace(/-+/g, '-').toLowerCase();
  }

  function showFormMessage(message, type) {
    formMessage.textContent = message;
    formMessage.className = `form-message ${type}`;
    formMessage.scrollIntoView({
      behavior: 'smooth',
      block: 'center'
    });
  }

  mediaInput?.addEventListener('change', () => {
    const file = mediaInput.files?.[0];

    if (file && selectedFile) {
      selectedFile.textContent = `${file.name} (${Math.round(file.size / 1024)} KB)`;
    } else if (selectedFile) {
      selectedFile.textContent = 'No file selected';
    }

    setFieldError('issueMedia', '');
  });

  document.getElementById('issueDescription')?.addEventListener('input', () => {
    setFieldError('issueDescription', '');
  });

  document.getElementById('contactEmail')?.addEventListener('input', () => {
    setFieldError('contactEmail', '');
  });

  if (form) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (!validateForm()) {
        return;
      }

      submitBtn.disabled = true;
      btnText.style.display = 'none';
      btnLoader.style.display = 'inline';

      const formData = new FormData(form);
      const file = mediaInput.files[0];
      const safeName = sanitizeFileName(file.name);
      const storagePath = `bug-reports/${Date.now()}-${safeName}`;
      const mediaRef = ref(storage, storagePath);

      try {
        const snapshot = await uploadBytes(mediaRef, file, {
          contentType: file.type || 'application/octet-stream'
        });
        const mediaUrl = await getDownloadURL(snapshot.ref);

        await addDoc(collection(db, 'bugReports'), {
          issueArea: formData.get('issueArea') || 'Not specified',
          issueDescription: formData.get('issueDescription'),
          deviceInfo: formData.get('deviceInfo') || '',
          contactEmail: formData.get('contactEmail') || '',
          mediaUrl,
          mediaStoragePath: storagePath,
          mediaFileName: file.name,
          mediaType: file.type,
          mediaSize: file.size,
          pageUrl: window.location.href,
          userAgent: navigator.userAgent,
          createdAt: serverTimestamp(),
          status: 'new'
        });

        showFormMessage('Thank you. Your bug report has been submitted to the WoofCare team.', 'success');
        form.reset();

        if (selectedFile) {
          selectedFile.textContent = 'No file selected';
        }
      } catch (error) {
        console.error('Error submitting bug report:', error);
        showFormMessage(`Error: ${error.message}. Please try again or contact woofcareepics@gmail.com.`, 'error');
      } finally {
        submitBtn.disabled = false;
        btnText.style.display = 'inline';
        btnLoader.style.display = 'none';

        setTimeout(() => {
          formMessage.style.display = 'none';
        }, 10000);
      }
    });
  }
</script>
